# Copy this file to .env and fill in your details.
# .env is listed in .gitignore — it will never be committed.

# ---------- Site Login ----------
RAYNES_PARK_BOOKING_USERNAME=your_email@example.com
RAYNES_PARK_BOOKING_PASSWORD=your_password

# ---------- Payment ----------
# Payment details are shared across sites.
# Your card details are stored only on your Mac, never uploaded anywhere.
# Use a virtual card with a low spend limit (Revolut / Monzo) for extra safety.
CARD_NUMBER=1234567890123456
CARD_EXPIRY=12/27
CARD_CVV=123
CARD_NAME=Your Full Name
