# Copy this file to .env and fill in your details.
# .env is listed in .gitignore — it will never be committed.

# ---------- Site Login ----------
RAYNES_PARK_BOOKING_USERNAME=your_email@example.com
RAYNES_PARK_BOOKING_PASSWORD=your_password
# ClubSpark uses named accounts. Account "a" is the implicit default if --account is omitted.
CLUB_SPARK_A_BOOKING_USERNAME=your_primary_clubspark_username
CLUB_SPARK_A_BOOKING_PASSWORD=your_primary_clubspark_password
CLUB_SPARK_B_BOOKING_USERNAME=your_secondary_clubspark_username
CLUB_SPARK_B_BOOKING_PASSWORD=your_secondary_clubspark_password

# ---------- Payment ----------
# Payment details are shared across sites.
# Your card details are stored only on your Mac, never uploaded anywhere.
# Use a virtual card with a low spend limit (Revolut / Monzo) for extra safety.
CARD_NUMBER=1234567890123456
CARD_EXPIRY=12/27
CARD_CVV=123
CARD_NAME=Your Full Name

# ---------- ClubSpark Experiments ----------
# Optional: precreate the Stripe payment method shortly before release and reuse it after release.
# This is experimental and intended to shave one Stripe round trip off the hot path.
CLUB_SPARK_PRECREATE_STRIPE_PM=0
CLUB_SPARK_PRECREATE_STRIPE_PM_LEAD_SECONDS=15
CLUB_SPARK_PRECREATED_STRIPE_PM_MAX_AGE_SECONDS=90
